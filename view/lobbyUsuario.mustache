<div class="main">
    <div class="card-usuario">
        <div class="icono">
            <svg xmlns="http://www.w3.org/2000/svg" id="icon" width="130" height="130" fill="currentColor" class="bi bi-person-circle" viewBox="0 0 16 16">
                <path d="M11 6a3 3 0 1 1-6 0 3 3 0 0 1 6 0"/>
                <path fill-rule="evenodd" d="M0 8a8 8 0 1 1 16 0A8 8 0 0 1 0 8m8-7a7 7 0 0 0-5.468 11.37C3.242 11.226 4.805 10 8 10s4.757 1.225 5.468 2.37A7 7 0 0 0 8 1"/>
            </svg>
        </div>
        <div>
            <h2 class="text-light">{{usuario}}</h2>
            <div class="botones">
                <button class="p-2 btn-violeta">Editar perfil</button>
                <button class="p-2 btn-blue">Cerrar sesion</button>
            </div>
        </div>
    </div>

    <div class="desafios">
        <div>
            <h2>DESAFIOS</h2>
        </div>
        <div class="d-flex flex-column gap-4 align-items-center text-white mx-4">
            {{#desafios}}
                <div class="fila-usuario">
                    <div class="usuario">
                        <svg xmlns="http://www.w3.org/2000/svg" id="icon" width="50" height="50" fill="currentColor" class="bi bi-person-circle" viewBox="0 0 16 16">
                            <path d="M11 6a3 3 0 1 1-6 0 3 3 0 0 1 6 0"/>
                            <path fill-rule="evenodd" d="M0 8a8 8 0 1 1 16 0A8 8 0 0 1 0 8m8-7a7 7 0 0 0-5.468 11.37C3.242 11.226 4.805 10 8 10s4.757 1.225 5.468 2.37A7 7 0 0 0 8 1"/>
                        </svg>
                        <p class="m-0 fs-4 fw-medium">{{nombre}}</p>
                    </div>
                    <p class="m-0 fs-5 fw-semibold p-2 rounded-5 w-150px texto-verde fondo-violetaoscuro">Aceptar</p>
                </div>
            {{/desafios}}
